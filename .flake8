[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .venv,
    venv,
    env,
    LifeOS/pgdata,
    LifeOS/Archive,
    .github,
    node_modules
# Per-file ignores for generated/test helpers
per-file-ignores =
    LifeOS/Scripts/tests/*: D, S101

# Plugins can be added in CI or developer environments; keep core rules conservative.
